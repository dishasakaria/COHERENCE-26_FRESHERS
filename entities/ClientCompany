{
  "name": "ClientCompany",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "industry": {
      "type": "string"
    },
    "contact_name": {
      "type": "string"
    },
    "contact_email": {
      "type": "string"
    },
    "plan": {
      "type": "string",
      "enum": [
        "starter",
        "growth",
        "enterprise"
      ],
      "default": "starter"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "onboarding",
        "churned"
      ],
      "default": "onboarding"
    },
    "health_score": {
      "type": "number",
      "default": 75
    },
    "monthly_cost": {
      "type": "number"
    },
    "emails_sent_this_month": {
      "type": "number",
      "default": 0
    },
    "api_calls_used": {
      "type": "number",
      "default": 0
    },
    "leads_stored": {
      "type": "number",
      "default": 0
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "paid",
        "due",
        "overdue"
      ],
      "default": "paid"
    },
    "renewal_date": {
      "type": "string",
      "format": "date"
    },
    "sender_personality": {
      "type": "object"
    },
    "ai_instructions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "logo_url": {
      "type": "string"
    }
  },
  "required": [
    "name"
  ]
}