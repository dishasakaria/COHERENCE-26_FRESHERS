{
  "name": "Meeting",
  "type": "object",
  "properties": {
    "lead_id": {
      "type": "string"
    },
    "lead_name": {
      "type": "string"
    },
    "lead_company": {
      "type": "string"
    },
    "lead_title": {
      "type": "string"
    },
    "lead_disc": {
      "type": "string"
    },
    "client_company_id": {
      "type": "string"
    },
    "scheduled_date": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "completed",
        "cancelled",
        "no_show"
      ],
      "default": "pending"
    },
    "meeting_type": {
      "type": "string"
    },
    "prep_brief": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "lead_name",
    "scheduled_date"
  ]
}